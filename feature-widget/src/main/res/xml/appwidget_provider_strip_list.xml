<?xml version="1.0" encoding="utf-8"?>
<!-- Strip List variant: pre-sized to 200×409dp so it opens in vertical list mode immediately. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="200dp"
    android:minHeight="409dp"
    android:minResizeWidth="130dp"
    android:minResizeHeight="150dp"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_strip"
    android:previewImage="@drawable/widget_preview_image_strip"
    android:previewLayout="@layout/widget_preview_strip"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_desc_strip_list"
    android:targetCellWidth="3"
    android:targetCellHeight="5" />
