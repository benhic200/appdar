<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <!-- Widget provider (merged into the app) -->
        <receiver
            android:name=".NearbyAppsWidgetProvider"
            android:exported="true"
            android:label="@string/widget_name_list">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.benhic.appdar.ACTION_PAGE_CHANGE" />
                <action android:name="com.benhic.appdar.ACTION_SCHEDULED_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_provider" />
        </receiver>

        <receiver
            android:name=".NearbyAppsWidgetProviderNano"
            android:exported="true"
            android:label="@string/widget_name_nano">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.benhic.appdar.ACTION_PAGE_CHANGE" />
                <action android:name="com.benhic.appdar.ACTION_SCHEDULED_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_provider_nano" />
        </receiver>

        <receiver
            android:name=".NearbyAppsWidgetProviderStrip"
            android:exported="true"
            android:label="@string/widget_name_strip">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.benhic.appdar.ACTION_PAGE_CHANGE" />
                <action android:name="com.benhic.appdar.ACTION_SCHEDULED_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_provider_strip" />
        </receiver>

        <receiver
            android:name=".NearbyAppsWidgetProviderGrid"
            android:exported="true"
            android:label="@string/widget_name_grid">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.benhic.appdar.ACTION_PAGE_CHANGE" />
                <action android:name="com.benhic.appdar.ACTION_SCHEDULED_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_provider_grid" />
        </receiver>

        <receiver
            android:name=".NearbyAppsWidgetProviderNarrow"
            android:exported="true"
            android:label="@string/widget_name_narrow">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.benhic.appdar.ACTION_PAGE_CHANGE" />
                <action android:name="com.benhic.appdar.ACTION_SCHEDULED_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_provider_narrow" />
        </receiver>

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>