<?xml version="1.0" encoding="utf-8"?>
<!--
    Static vector preview of the Nearby Apps Widget shown in the launcher's
    widget picker on API < 31 devices (android:previewImage).
    Draws a simplified 4×2 widget card: purple header bar, three list rows,
    and a small refresh icon — no external drawables or theme references.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="160dp"
    android:viewportWidth="320"
    android:viewportHeight="160">

    <!-- Widget card background: faint lavender, rounded corners -->
    <path
        android:pathData="M 12,0 L 308,0 Q 320,0 320,12 L 320,148 Q 320,160 308,160 L 12,160 Q 0,160 0,148 L 0,12 Q 0,0 12,0 Z"
        android:fillColor="#FF1C1A2E" />

    <!-- Header bar background -->
    <path
        android:pathData="M 0,0 L 320,0 L 320,36 L 0,36 Z"
        android:fillColor="#FFF3E5F5" />

    <!-- Header: "Nearby Apps" label (represented as rounded rect) -->
    <path
        android:pathData="M 12,13 L 130,13 Q 134,13 134,17 L 134,23 Q 134,27 130,27 L 12,27 Q 8,27 8,23 L 8,17 Q 8,13 12,13 Z"
        android:fillColor="#FFCE93D8" />

    <!-- Header: refresh icon (two arcs suggesting rotation) -->
    <path
        android:pathData="M 302,11 A 8,8,0,1,0,310,19"
        android:fillColor="#00000000"
        android:strokeColor="#FFCE93D8"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
    <path
        android:pathData="M 310,19 L 313,15 L 307,15 Z"
        android:fillColor="#FFCE93D8" />

    <!-- Header: settings gear dot (simplified) -->
    <path
        android:pathData="M 283,18 A 5,5,0,1,0,283,18.01 Z"
        android:fillColor="#FFCE93D8" />

    <!-- Divider below header -->
    <path
        android:pathData="M 0,36 L 320,36"
        android:fillColor="#00000000"
        android:strokeColor="#FFCE93D8"
        android:strokeWidth="0.5" />

    <!-- ── Row 1 ── -->
    <!-- Status dot: installed (purple) -->
    <path
        android:pathData="M 14,60 A 4,4,0,1,0,14,60.01 Z"
        android:fillColor="#FFCE93D8" />

    <!-- App icon placeholder (rounded square) -->
    <path
        android:pathData="M 26,48 L 50,48 Q 54,48 54,52 L 54,68 Q 54,72 50,72 L 26,72 Q 22,72 22,68 L 22,52 Q 22,48 26,48 Z"
        android:fillColor="#FFE8D5F5" />

    <!-- Business name bar -->
    <path
        android:pathData="M 60,50 L 160,50 Q 162,50 162,52 L 162,56 Q 162,58 160,58 L 60,58 Q 58,58 58,56 L 58,52 Q 58,50 60,50 Z"
        android:fillColor="#FF212121" />

    <!-- Distance chip -->
    <path
        android:pathData="M 60,62 L 94,62 Q 96,62 96,64 L 96,70 Q 96,72 94,72 L 60,72 Q 58,72 58,70 L 58,64 Q 58,62 60,62 Z"
        android:fillColor="#FFF3E5F5" />
    <path
        android:pathData="M 62,64 L 90,64 Q 92,64 92,66 L 92,68 Q 92,70 90,70 L 62,70 Q 60,70 60,68 L 60,64 Q 60,64 62,64 Z"
        android:fillColor="#FFCE93D8" />

    <!-- ── Row 2 ── -->
    <path
        android:pathData="M 14,100 A 4,4,0,1,0,14,100.01 Z"
        android:fillColor="#FFCE93D8" />

    <path
        android:pathData="M 26,88 L 50,88 Q 54,88 54,92 L 54,108 Q 54,112 50,112 L 26,112 Q 22,112 22,108 L 22,92 Q 22,88 26,88 Z"
        android:fillColor="#FFE8D5F5" />

    <path
        android:pathData="M 60,90 L 140,90 Q 142,90 142,92 L 142,96 Q 142,98 140,98 L 60,98 Q 58,98 58,96 L 58,92 Q 58,90 60,90 Z"
        android:fillColor="#FF212121" />

    <path
        android:pathData="M 60,102 L 102,102 Q 104,102 104,104 L 104,110 Q 104,112 102,112 L 60,112 Q 58,112 58,110 L 58,104 Q 58,102 60,102 Z"
        android:fillColor="#FFF3E5F5" />
    <path
        android:pathData="M 62,104 L 100,104 Q 102,104 102,106 L 102,108 Q 102,110 100,110 L 62,110 Q 60,110 60,108 L 60,104 Q 60,104 62,104 Z"
        android:fillColor="#FFCE93D8" />

    <!-- ── Row 3 (faded — not installed) ── -->
    <path
        android:pathData="M 14,138 A 4,4,0,1,0,14,138.01 Z"
        android:fillColor="#FF9B8FB0" />

    <path
        android:pathData="M 26,126 L 50,126 Q 54,126 54,130 L 54,146 Q 54,150 50,150 L 26,150 Q 22,150 22,146 L 22,130 Q 22,126 26,126 Z"
        android:fillColor="#FFE8D5F5" />

    <path
        android:pathData="M 60,128 L 170,128 Q 172,128 172,130 L 172,134 Q 172,136 170,136 L 60,136 Q 58,136 58,134 L 58,130 Q 58,128 60,128 Z"
        android:fillColor="#FF9E9E9E" />

    <path
        android:pathData="M 60,140 L 110,140 Q 112,140 112,142 L 112,148 Q 112,150 110,150 L 60,150 Q 58,150 58,148 L 58,142 Q 58,140 60,140 Z"
        android:fillColor="#FFE8D5F5" />
    <path
        android:pathData="M 62,142 L 108,142 Q 110,142 110,144 L 110,146 Q 110,148 108,148 L 62,148 Q 60,148 60,146 L 60,142 Q 60,142 62,142 Z"
        android:fillColor="#FF9B8FB0" />

</vector>
