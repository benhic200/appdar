<?xml version="1.0" encoding="utf-8"?>
<!-- Nano widget: shows the single closest business. ~1x1 to ~2x1 cell. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nano_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_ripple_row"
    android:clickable="true"
    android:focusable="true"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/nano_app_icon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:contentDescription="@string/app_icon_description"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/nano_business_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FF212121"
            android:textSize="11sp" />

        <LinearLayout
            android:id="@+id/nano_chip_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/nano_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_background"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:textColor="#FF6A1B9A"
                android:textSize="10sp"
                android:maxLines="1" />

            <ImageView
                android:id="@+id/nano_status_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginStart="4dp"
                android:importantForAccessibility="no" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tiny refresh button pinned to top-right corner -->
    <ImageView
        android:id="@+id/nano_refresh"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:src="@android:drawable/ic_menu_rotate"
        android:contentDescription="@string/refresh"
        android:padding="2dp"
        android:tint="#FFAB47BC"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/widget_ripple_icon" />

</FrameLayout>
