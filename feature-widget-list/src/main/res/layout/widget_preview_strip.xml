<?xml version="1.0" encoding="utf-8"?>
<!--
    Static preview layout for the strip widget shown in the widget picker (android:previewLayout, API 31+).
    Hardcoded sample data — never receives RemoteViews updates.
    Must not use Space, GridLayout, or ?android:attr/ theme references.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1C1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="2dp"
        android:paddingEnd="22dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <!-- Item 1: Costa Coffee, 120 m -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="8dp"
            android:background="#FF1C1A2E">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/sym_def_app_icon"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Costa Coffee"
                android:textColor="#FF212121"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:background="@drawable/chip_background_dark"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:text="120 m"
                android:textColor="#FF6A1B9A"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_installed_dot"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <!-- Item 2: Tesco, 340 m -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="8dp"
            android:background="#FF1C1A2E">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/sym_def_app_icon"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Tesco"
                android:textColor="#FF212121"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:background="@drawable/chip_background_dark"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:text="340 m"
                android:textColor="#FF6A1B9A"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_installed_dot"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <!-- Item 3: McDonald's, 0.5 km -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="8dp"
            android:background="#FF1C1A2E">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/sym_def_app_icon"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="McDonald\'s"
                android:textColor="#FF212121"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:background="@drawable/chip_background_dark"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:text="0.5 km"
                android:textColor="#FF6A1B9A"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_uninstalled_dot"
                android:importantForAccessibility="no" />
        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:src="@android:drawable/ic_menu_rotate"
        android:contentDescription="@string/refresh"
        android:padding="2dp"
        android:tint="#FFCE93D8"
        android:importantForAccessibility="no"
        android:background="#00000000" />

</FrameLayout>
