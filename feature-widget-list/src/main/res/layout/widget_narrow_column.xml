<?xml version="1.0" encoding="utf-8"?>
<!--
    Narrow column (light) — used when width < 80dp but height >= 150dp.
    Icons stacked vertically, no text. Items added via addView().
    MIUI-safe: no Space, no ?android:attr/, no GridLayout.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF8FF">

    <LinearLayout
        android:id="@+id/narrow_icons_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="20dp"
        android:paddingBottom="2dp" />

    <ImageView
        android:id="@+id/narrow_refresh"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:src="@android:drawable/ic_menu_rotate"
        android:contentDescription="@string/refresh"
        android:padding="2dp"
        android:tint="#FFAB47BC"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/widget_ripple_icon" />

</FrameLayout>
