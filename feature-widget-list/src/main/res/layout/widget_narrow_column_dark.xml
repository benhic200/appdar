<?xml version="1.0" encoding="utf-8"?>
<!--
    Narrow column (dark) — used when width < 80dp but height >= 150dp.
    Icons stacked vertically, no text. Items added via addView().
    MIUI-safe: no Space, no ?android:attr/, no GridLayout.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1C1A2E">

    <LinearLayout
        android:id="@+id/narrow_icons_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

</FrameLayout>
