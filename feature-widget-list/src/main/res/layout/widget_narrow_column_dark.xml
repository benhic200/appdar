<?xml version="1.0" encoding="utf-8"?>
<!--
    Narrow column (dark) — used when width < 80dp and height >= 150dp.
    Refresh button is always pinned at the top of the LinearLayout — never
    overlaid or clipped, even at 56dp width.
    Icons stacked vertically below it, added via addView().
    MIUI-safe: no Space, no ?android:attr/, no GridLayout.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1C1A2E">

    <!-- Refresh button pinned at the very top -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:paddingEnd="1dp">

        <ImageView
            android:id="@+id/narrow_refresh"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:contentDescription="@string/refresh"
            android:padding="2dp"
            android:tint="#FFCE93D8"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/widget_ripple_icon" />

    </LinearLayout>

    <!-- Icons fill the remaining height -->
    <LinearLayout
        android:id="@+id/narrow_icons_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="2dp" />

</LinearLayout>
