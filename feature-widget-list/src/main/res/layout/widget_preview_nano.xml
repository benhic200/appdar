<?xml version="1.0" encoding="utf-8"?>
<!--
    Static preview layout for the nano widget shown in the widget picker (android:previewLayout, API 31+).
    Matches widget_nano_short.xml (horizontal layout used at ≤90dp height / 2×1 target cell).
    Hardcoded sample data — never receives RemoteViews updates.
    Must not use Space, GridLayout, or ?android:attr/ theme references.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nano_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1C1A2E"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/nano_app_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:contentDescription="@string/app_icon_description"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/nano_business_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Costa Coffee"
                android:textColor="#FF212121"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/nano_chip_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/nano_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120 m"
                    android:textColor="#FF6A1B9A"
                    android:textSize="9sp"
                    android:maxLines="1" />

                <ImageView
                    android:id="@+id/nano_status_dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_installed_dot"
                    android:importantForAccessibility="no" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/nano_refresh"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:src="@android:drawable/ic_menu_rotate"
        android:contentDescription="@string/refresh"
        android:padding="2dp"
        android:tint="#FFCE93D8"
        android:importantForAccessibility="no"
        android:background="#00000000" />

</FrameLayout>
