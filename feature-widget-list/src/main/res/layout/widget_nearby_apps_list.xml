<?xml version="1.0" encoding="utf-8"?>
<!--
    Light-theme widget root layout, API 31+.
    NO theme attributes (?android:attr/...) — inflated by the launcher process which
    may not have our app theme. All colours are hardcoded.
    NO <Space> — not guaranteed to be in MIUI's RemoteViews whitelist.
    items_container is a LinearLayout so addView() works without LayoutParams.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F5F5">

    <!-- Header row: pagination controls + settings + refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/widget_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:visibility="gone"
            android:text="@string/nearby_apps"
            android:textColor="#FF212121" />

        <ImageView
            android:id="@+id/btn_prev_page"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Previous page"
            android:padding="4dp"
            android:tint="#FF757575"
            android:clickable="true"
            android:focusable="true"
            android:background="#00000000" />

        <TextView
            android:id="@+id/tv_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:textColor="#FF757575" />

        <ImageView
            android:id="@+id/btn_next_page"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Next page"
            android:padding="4dp"
            android:tint="#FF757575"
            android:clickable="true"
            android:focusable="true"
            android:background="#00000000" />

        <!-- Weight-1 TextView replaces Space — Space is not in MIUI's RemoteViews whitelist -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/settings_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_settings_gear"
            android:contentDescription="Settings"
            android:padding="4dp"
            android:tint="#FF757575"
            android:clickable="true"
            android:focusable="true"
            android:background="#00000000" />

        <ImageView
            android:id="@+id/refresh_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:contentDescription="@string/refresh"
            android:padding="4dp"
            android:tint="#FF757575"
            android:clickable="true"
            android:focusable="true"
            android:background="#00000000" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/items_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp" />

</LinearLayout>
