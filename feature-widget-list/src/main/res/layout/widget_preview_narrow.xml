<?xml version="1.0" encoding="utf-8"?>
<!--
    Static preview layout for the narrow column widget shown in the widget picker (android:previewLayout, API 31+).
    Hardcoded sample data — never receives RemoteViews updates.
    Must not use Space, GridLayout, or ?android:attr/ theme references.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1C1A2E">

    <!-- Refresh button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:paddingEnd="1dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:padding="2dp"
            android:tint="#FFCE93D8"
            android:importantForAccessibility="no"
            android:background="#00000000" />

    </LinearLayout>

    <!-- Sample icon 1 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:padding="3dp">
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Sample icon 2 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:padding="3dp">
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Sample icon 3 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:padding="3dp">
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Sample icon 4 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:padding="3dp">
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />
    </FrameLayout>

</LinearLayout>
