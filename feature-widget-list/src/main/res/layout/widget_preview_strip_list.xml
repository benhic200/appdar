<?xml version="1.0" encoding="utf-8"?>
<!--
    Static preview layout for the Strip List (3×5) widget shown in the picker (android:previewLayout, API 31+).
    Displays 5 icon + name rows stacked vertically to match the actual widget appearance.
    Hardcoded sample data — never receives RemoteViews updates.
    Must not use Space, GridLayout, or ?android:attr/ theme references.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1C1A2E"
    android:padding="4dp">

    <!-- Row 1: Costa Coffee, 120 m -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Costa Coffee"
            android:textColor="#FFE8D5F5"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/chip_background_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="120 m"
            android:textColor="#FFCE93D8"
            android:textSize="10sp"
            android:maxLines="1" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" />

    <!-- Row 2: Tesco, 340 m -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Tesco"
            android:textColor="#FFE8D5F5"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/chip_background_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="340 m"
            android:textColor="#FFCE93D8"
            android:textSize="10sp"
            android:maxLines="1" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" />

    <!-- Row 3: McDonald's, 0.5 km -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="McDonald\'s"
            android:textColor="#FFE8D5F5"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/chip_background_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="0.5 km"
            android:textColor="#FFCE93D8"
            android:textSize="10sp"
            android:maxLines="1" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" />

    <!-- Row 4: Starbucks, 0.8 km -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Starbucks"
            android:textColor="#FFE8D5F5"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/chip_background_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="0.8 km"
            android:textColor="#FFCE93D8"
            android:textSize="10sp"
            android:maxLines="1" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" />

    <!-- Row 5: KFC, 1.2 km (not installed — dimmed) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:alpha="0.45">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="KFC"
            android:textColor="#FFE8D5F5"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/chip_background_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="1.2 km"
            android:textColor="#FFCE93D8"
            android:textSize="10sp"
            android:maxLines="1" />
    </LinearLayout>

</LinearLayout>
