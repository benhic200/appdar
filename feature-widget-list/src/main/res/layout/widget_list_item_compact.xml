<?xml version="1.0" encoding="utf-8"?>
<!-- Light-theme compact cell for the two-column grid. NO theme attributes. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/compact_item_root"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="8dp"
    android:clickable="true"
    android:focusable="true"
    android:background="#FFF5F5F5">

    <ImageView
        android:id="@+id/compact_app_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/app_icon_description"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/compact_business_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#FF212121"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/compact_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:background="@drawable/chip_background"
        android:paddingStart="6dp"
        android:paddingTop="2dp"
        android:paddingEnd="6dp"
        android:paddingBottom="2dp"
        android:textColor="#FF757575"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <ImageView
        android:id="@+id/compact_status_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginTop="4dp"
        android:importantForAccessibility="no" />

</LinearLayout>
