<?xml version="1.0" encoding="utf-8"?>
<!-- Strip widget: compact list of 3 businesses, no pagination chrome. ~2x2 to 3x2 cells. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/strip_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFDF8FF">

    <!-- Minimal header: just a refresh icon pinned to the right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/strip_page_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FF6B5B95"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/strip_settings"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_settings_gear"
            android:contentDescription="Open Appdar"
            android:padding="3dp"
            android:tint="#FFAB47BC"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/widget_ripple_icon" />

        <ImageView
            android:id="@+id/strip_refresh"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:contentDescription="@string/refresh"
            android:padding="3dp"
            android:tint="#FFAB47BC"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/widget_ripple_icon" />
    </LinearLayout>

    <!-- Items added via addView() — uses item_root, app_icon, business_name, distance, status_dot IDs -->
    <LinearLayout
        android:id="@+id/strip_items_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

</LinearLayout>
